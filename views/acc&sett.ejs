<!-- ==========================================================

Description:
Account & Settings page template.

This view provides the user interface for managing:
- User profile information display
- Theme preferences (light / dark mode)
- Language selection
- Security-related actions (password, logout, data migration)

Layout:
- Includes global header and footer partials.
- Structured using BEM naming convention.
- Organized into logical sections: user info, preferences, security.

Client-Side Behavior:
- Theme toggle is controlled via JavaScript (localStorage + class switching).
- Language toggle integrates with the i18n system (data-i18n attributes).
- Security buttons are dynamically enabled/disabled based on
  authentication state.
- Logout and password change actions are handled by frontend modules.

Dependencies:
- theme&lang.js
- authState.js
- password.js
- acc&sett.js
- dark.js (if applicable)
- Global bundle.min.js

Notes:
- Buttons are initially disabled to prevent unauthorized interaction.
- User name is dynamically injected via JavaScript.
- Internationalization is handled client-side using data-i18n keys.
========================================================== -->


<%- include('partials/header') %>

<section class="settings">

  <h2 class="settings__h2" data-i18n="account_settings"></h2>

  <!-- Info del usuario -->
  <div class="settings__user">
    <p class="settings__user--userName"></p>
  </div>

  <!-- Tema -->
  <div class="settings__option">
    <div class="settings__option--theme-switcher">
      <label for="theme-toggle" data-i18n="theme"></label>
      <button id="theme-toggle">Light 🌞</button>
    </div>
  </div>

  <!-- Idioma -->
  <div class="settings__option">
    <div class="settings__option--lang-switcher">
      <label for="lang-toggle" data-i18n="language"></label>
      <button id="lang-toggle">Español 🇪🇸</button>
    </div>
  </div>

  <!-- Seguridad -->
  <div class="settings__security">
  
    <button type="button" id="change-password-btn" class="settings__security--btn settings__security--btnSecondary" disabled data-i18n="change_password"></button>

    <button type="button" id="logout-btn" class="settings__security--btn settings__security--btnDanger" disabled data-i18n="logout"></button>

    <button
      type="button"
      id="migrate-notes-btn"
      class="settings__security--btn settings__security--btnTerciary"
      disabled
      data-i18n="migrate_notes">
    </button>
  </div>

</section>

<%- include('partials/footer') %>