<!-- 
==========================================================
Description:
Footer partial template rendered across application views.

Responsibilities:
- Closes the main content container.
- Displays dynamic copyright year.
- Provides external LinkedIn profile link.
- Loads the compiled frontend JavaScript bundle.

Server Variables:
- year → Injected from the backend to dynamically display
  the current year.

Client Dependencies:
- bundle.min.js → Compiled and minified Webpack output.
- Font Awesome (for LinkedIn icon rendering).
- i18n system (data-i18n attribute for translated text).

Notes:
- The data-i18n attribute allows dynamic language switching.
- The LinkedIn link opens in a new secure tab using
  rel="noopener noreferrer" for security best practices.
- This partial is intended to be included in layout templates.
========================================================== -->
    </main>
    <footer class="footer">
      <div class="footer__grid">
        <p><span class="footer__year">&copy; <%= year %></span><span class="footer__texto" data-i18n="footer_text"></span></p>

        <nav class="linkdln">
          <a href="https://www.linkedin.com/in/wilfredery-a-dilon%C3%A9-cordero-a23386279/" target="_blank" rel="noopener noreferrer">
            <p class="linkdln__title" data-i18n="dev">Developed by</p><i class="fa-brands fa-linkedin"></i>
            
          </a>
        </nav>
      </div>
    </footer>
    <script src="/build/js/bundle.min.js"></script>
</body>
</html>