<!-- ==========================================================
(Base Layout Template)

Description:
Main layout template used across the application.

This file defines:
- Global HTML structure
- Metadata and external resources
- Header navigation
- Theme initialization logic
- Main content wrapper

Server Variables:
- title → Injected dynamically to define the page title.

Client Responsibilities:
- Applies saved theme preference from localStorage.
- Loads global CSS styles.
- Provides responsive navigation menu.
- Supports internationalization via data-i18n attributes.
- Displays different navigation options based on auth state
  (controlled by frontend JavaScript).

Dependencies:
- Compiled CSS: /build/css/app.css
- Google Fonts (Nunito Sans)
- Font Awesome (icons)
- Frontend bundle loaded in footer partial

Notes:
- Dark mode is applied before full render to prevent flash.
- Header visibility is controlled via JavaScript.
- This layout is intended to wrap individual view templates.
========================================================== -->

<!DOCTYPE html>
<html lang="en">
<head>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const theme = localStorage.getItem('theme');
    if (theme === 'dark') document.body.classList.add('dark');
  });
</script>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/build/css/app.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito+Sans:ital,opsz,wght@0,6..12,200..1000;1,6..12,200..1000&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>

</head>
<body>
    
    <header id="main-header" class="header hidden">
        
        <div class="header__logo">
            <a href="/"><h1 class="header__titulo">My<span class="header__spanTitulo">Notes</span></h1></a>
        </div>

        <div class="menu-container">
            <!-- Botón del menú hamburguesa -->
            <button class="menu-btn" aria-label="Open menu">
            <i class="fa-solid fa-bars"></i>
            </button>

            <!-- Menú desplegable -->
            <nav class="dropdown-menu">
                <ul>
                    <!-- LINKS NORMALES -->
                    <li><a href="/search"><span>🔍</span><span data-i18n="page_searchNotes"></span></a></li>
                    <li><a href="/crear"><span>✏️</span><span data-i18n="crearNota"></span></a></li>
                    <li><a href="/account-settings"><span>🧑</span><span data-i18n="page_accountSettings"></span><span>⚙️</span></a></li>
                    <li id="guest-controls" style="display:none">
                    <a href="/login"><span>🔐</span><span data-i18n="login"></span></a>
                    </li>

                    <li id="guest-controls-register" style="display:none">
                    <a href="/register"><span>📝</span><span data-i18n="register"></span></a>
                    </li>
                </ul>
            </nav>
        </div>
    </header>

    <main class="shadowbox">